        help_text += "/ping - Проверить работоспособность бота\n"
        help_text += "/status - Статус бота и статистика\n"
        help_text += "/id - Показать ваш ID\n"
        help_text += "/feedback - Оставить отзыв о боте\n\n"

        # Команды администраторов
        if user_id in ADMIN_IDS:
            help_text += "👑 КОМАНДЫ АДМИНИСТРАТОРА:\n"
            help_text += "/admin - Панель администратора\n"
            help_text += "/stats - Статистика бота\n"
            help_text += "/admins - Список администраторов\n"
            help_text += "/moderators - Список модераторов\n"
            help_text += "/users - Список всех пользователей\n"
            help_text += "/finduser - Поиск пользователя\n"
            help_text += "/recentusers - Новые пользователи\n"
            help_text += "/userinfo - Информация о пользователе\n"
            help_text += "/ban - Заблокировать пользователя\n"
            help_text += "/unban - Разблокировать пользователя\n"
            help_text += "/banned - Список заблокированных\n"
            help_text += "/addadmin - Добавить администратора\n"
            help_text += "/removeadmin - Удалить администратора\n"
            help_text += "/addmoderator - Добавить модератора\n"
            help_text += "/removemoderator - Удалить модератора\n"
            help_text += "/blacklist - Управление черными списками\n"
            help_text += "/broadcast - Рассылка сообщений\n"
            help_text += "/notify - Уведомить пользователя\n"
            help_text += "/logs - Логи действий\n"
            help_text += "/feedback_list - Список отзывов\n"
            help_text += "/maintenance - Режим обслуживания\n"
            help_text += "/cleanup - Очистка старых данных\n"
            help_text += "/export - Экспорт данных\n"
            help_text += "/backup - Backup базы данных\n\n"

        # Команды модераторов
        if user_id in MODERATOR_IDS:
            help_text += "🛡️ КОМАНДЫ МОДЕРАТОРА:\n"
            help_text += "/moderator - Панель модератора\n"
            help_text += "/blacklist - Просмотр черных списков\n"

        await update.message.reply_text(help_text)

    async def question(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        # Проверяем, что бот вызван в личном чате
        if not await self.check_private_chat(update):
            return ConversationHandler.END

        user = update.message.from_user

        # Проверяем заблокирован ли пользователь
        if db.is_user_banned(user.id):
            await update.message.reply_text("❌ Вы заблокированы и не можете использовать этого бота.")
            return ConversationHandler.END

        await update.message.reply_text(
            "Задайте ваш вопрос и администрация клана ответит вам в ближайшее время:\n\n"
            "Или нажмите '❌ Отменить' для возврата в главное меню.",
            reply_markup=self.cancel_keyboard()
        )
        return QUESTION

    async def receive_question(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        # Проверяем, что бот вызван в личном чате
        if not await self.check_private_chat(update):
            return ConversationHandler.END

        user = update.message.from_user
        text = update.message.text

        # Проверяем заблокирован ли пользователь
        if db.is_user_banned(user.id):
            await update.message.reply_text("❌ Вы заблокированы и не можете использовать этого бота.")
            return ConversationHandler.END

        # Проверяем отмену
        if text == "❌ Отменить":
            await update.message.reply_text(
                "❌ Создание вопроса отменено.",
                reply_markup=self.main_keyboard(user.id)
            )
            return ConversationHandler.END

        db.add_question(user.id, text)
        db.log_action(user.id, "ask_question", f"Вопрос: {text[:50]}...")

        # Уведомляем пользователя
        await update.message.reply_text(
            "✅ Ваш вопрос отправлен администрации и находится на рассмотрении. Ожидайте ответа!",
            reply_markup=self.main_keyboard(user.id)
        )

        # Уведомляем админов
        for admin_id in ADMIN_IDS:
            try:
                await self.application.bot.send_message(
                    admin_id,
                    f"❓ Новый вопрос от @{user.username}:\n\n{text}"
                )
            except Exception as e:
                logger.error(f"Ошибка уведомления админа {admin_id}: {e}")

        return ConversationHandler.END

    async def moderation(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        # Проверяем, что бот вызван в личном чате
        if not await self.check_private_chat(update):
            return ConversationHandler.END

        user = update.message.from_user

        # Проверяем заблокирован ли пользователь
        if db.is_user_banned(user.id):
            await update.message.reply_text("❌ Вы заблокированы и не можете использовать этого бота.")
            return ConversationHandler.END

        await update.message.reply_text(
            "📝 Заполните анкету для подачи заявки в модераторы:\n\n"
            "‼️🇷🇺При написании заявки необходимо соблюдать все правила русского языка.🇷🇺‼️\n"
            "1️⃣. Ваш ник:  \n"
            "2️⃣. Ваш возраст:\n"
            "3️⃣. Выдавали блокировку игрокам на сервере?:\n"
            "4️⃣. Дайте определение словам Бан/Мут/Варн:\n"
            "5️⃣. Есть опыт модерирования?:\n"
            "6️⃣. Напишите небольшой рассказ о себе(не менее двадцати слов)\n"
            "7️⃣. Сколько времени Вы, готовы уделять набору в клан?\n"
            "8️⃣. Почему именно наш клан?\n"
            "9️⃣.Кто вас пригласил на стажёра? (Необязательно если узнали сами)\n\n"
            "                ‼️Важно‼️\n"
            "‼️Если вашу заявку одобряют, то вы становитесь на пост ✅стажёра✅ клана.‼️\n"
            "⚙️На стажёрке нельзя брать отгулы.⚙️\n"
            "‼️Максимальное время на стажировке -  7 дней с момента выдачи роли .‼️\n"
            "❌Получение 1 выговора на стажировке - снятие❌\n\n\n"
            "⚙️На рассмотрение заявки может уйти от 1️⃣ до 2️⃣ дней⚙️\n\n"
            "Отправьте всю информацию одним сообщением.\n"
            "Или нажмите '❌ Отменить' для возврата в главное меню.",
            reply_markup=self.cancel_keyboard()
        )
        return MODERATION

    async def receive_moderation(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        # Проверяем, что бот вызван в личном чате
        if not await self.check_private_chat(update):
            return ConversationHandler.END

        user = update.message.from_user
        text = update.message.text

        # Проверяем заблокирован ли пользователь
        if db.is_user_banned(user.id):
            await update.message.reply_text("❌ Вы заблокированы и не можете использовать этого бота.")
            return ConversationHandler.END

        # Проверяем отмену
        if text == "❌ Отменить":
            await update.message.reply_text(
                "❌ Подача заявки отменена.",
                reply_markup=self.main_keyboard(user.id)
            )
            return ConversationHandler.END

        db.add_application(user.id, text)
        db.log_action(user.id, "submit_application", f"Заявка: {text[:50]}...")

        # Уведомляем пользователя
        await update.message.reply_text(
            "✅ Ваша заявка отправлена на рассмотрение! "
            "Администрация свяжется с вами в ближайшее время.",
            reply_markup=self.main_keyboard(user.id)
        )

        # Уведомляем админов
        for admin_id in ADMIN_IDS:
            try:
                await self.application.bot.send_message(
                    admin_id,
                    f"📝 Новая заявка в модерацию от @{user.username}:\n\n{text}"
                )
            except Exception as e:
                logger.error(f"Ошибка уведомления админа {admin_id}: {e}")

        return ConversationHandler.END

    async def cancel(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        # Проверяем, что бот вызван в личном чате
        if not await self.check_private_chat(update):
            return ConversationHandler.END

        user_id = update.message.from_user.id
        await update.message.reply_text(
            "Диалог отменен.",
            reply_markup=self.main_keyboard(user_id)
        )
        return ConversationHandler.END

    async def handle_message(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        user_id = update.message.from_user.id
        text = update.message.text

        # Проверяем режим обслуживания
        if self.maintenance_mode and user_id not in ADMIN_IDS:
            await update.message.reply_text(
                "🔴 Бот временно находится в режиме обслуживания. "
                "Пожалуйста, попробуйте позже."
            )
            return

        # Проверяем заблокирован ли пользователь
        if db.is_user_banned(user_id):
            await update.message.reply_text("❌ Вы заблокированы и не можете использовать этого бота.")
            return

        # Проверяем, что бот вызван в личном чате
        if update.effective_chat.type != "private":
            # Если это не ЛС, но пользователь пытается что-то написать - игнорируем
            return

        # Обработка ответа на вопрос
        if 'answering_question' in context.user_data:
            question_id = context.user_data.pop('answering_question')
            question = db.get_question(question_id)

            try:
                await self.application.bot.send_message(
                    question['user_id'],
                    f"💬 Ответ от администрации на ваш вопрос:\n\n{text}"
                )
                db.update_question_status(question_id, "answered", user_id)
                db.log_action(user_id, "answer_question", f"Вопрос #{question_id}")
                await update.message.reply_text("✅ Ответ отправлен пользователю.",
                                                reply_markup=self.main_keyboard(user_id))
            except Exception as e:
                await update.message.reply_text("❌ Ошибка отправки ответа.", reply_markup=self.main_keyboard(user_id))
            return

        # Основные кнопки
        if text == "❓ Вопрос":
            return await self.question(update, context)
        elif text == "📝 Набор в модерацию":
            return await self.moderation(update, context)
        elif text == "📜 Информация о клане":
            await self.show_rules(update, context)
        elif text == "👑 Панель администратора" and user_id in ADMIN_IDS:
            await self.admin_panel(update, context)
        elif text == "🛡️ Панель модератора" and (user_id in MODERATOR_IDS or user_id in ADMIN_IDS):
            await self.moderator_panel(update, context)
        elif text == "💬 Обратная связь":
            return await self.feedback(update, context)
        elif text == "ℹ️ О боте":
            await self.bot_status(update, context)
        else:
            # Проверяем, не находимся ли мы в диалоге добавления/удаления из ЧС
            if context.user_data.get('awaiting_blacklist_add'):
                return await self.receive_blacklist_add(update, context)
            elif context.user_data.get('awaiting_blacklist_remove'):
                return await self.receive_blacklist_remove(update, context)
            elif context.user_data.get('awaiting_blacklist_search'):
                return await self.receive_blacklist_search(update, context)
            else:
                await update.message.reply_text(
                    "Используйте кнопки для навигации:",
                    reply_markup=self.main_keyboard(user_id)
                )

    async def button_handler(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        query = update.callback_query
        await query.answer()

        user_id = query.from_user.id

        # Проверяем режим обслуживания для обычных пользователей
        if self.maintenance_mode and user_id not in ADMIN_IDS:
            await query.edit_message_text(
                "🔴 Бот временно находится в режиме обслуживания. "
                "Пожалуйста, попробуйте позже."
            )
            return

        # Проверяем, что callback пришел из личного чата
        if query.message.chat.type != "private":
            await query.edit_message_text("❌ Бот работает только в личных сообщениях.")
            return

        if query.data == "admin_back" or query.data == "mod_back":
            await query.edit_message_text(
                "Возврат в главное меню:",
                reply_markup=None
            )
            await query.message.reply_text(
                "Панель закрыта.",
                reply_markup=self.main_keyboard(user_id)
            )
            return

        # Проверка прав для админских команд
        if user_id not in ADMIN_IDS and not query.data.startswith(("feedback_", "mod_", "bl_view_")):
            await query.edit_message_text("❌ У вас нет прав администратора.")
            return

        data = query.data

        # Обработка фидбека
        if data.startswith("feedback_"):
            if data == "feedback_cancel":
                await query.edit_message_text(
                    "❌ Отправка отзыва отменена.",
                    reply_markup=self.main_keyboard(user_id)
                )
                return

            elif data == "feedback_text":
                await query.edit_message_text(
                    "💬 Напишите ваш текстовый отзыв:\n\n"
                    "Или нажмите '❌ Отменить' для возврата.",
                    reply_markup=self.cancel_keyboard()
                )
                context.user_data['feedback_mode'] = True
                return FEEDBACK

            else:
                # Обработка рейтинга
                rating = int(data.split('_')[1])
                await query.edit_message_text(
                    f"⭐ Спасибо за оценку {rating}/5!\n"
                    f"Вы можете дополнить её текстовым отзывом:\n\n"
                    f"Или нажмите '❌ Отменить' для возврата.",
                    reply_markup=self.cancel_keyboard()
                )
                context.user_data['feedback_rating'] = rating
                context.user_data['feedback_mode'] = True
                return FEEDBACK

        # Админские команды
        if data == "admin_applications":
            await self.show_applications(query, context)
        elif data == "admin_questions":
            await self.show_questions(query, context)
        elif data == "admin_stats":
            await self.show_stats(query, context)
        elif data == "admin_banned":
            await self.show_banned_users_callback(query, context)
        elif data == "admin_users":
            await self.send_users_page(query, context, page=0)
        elif data == "admin_search_user":
            await query.edit_message_text(
                "🔍 Введите username, имя или фамилию пользователя для поиска:",
                reply_markup=InlineKeyboardMarkup([
                    [InlineKeyboardButton("🔙 Назад", callback_data="admin_back")]
                ])
            )
            context.user_data['searching_user'] = True
            return USER_SEARCH
        elif data == "admin_recent_users":
            await self.recent_users_callback(query, context)
        elif data == "admin_feedback":
            await self.show_feedback_callback(query, context)
        elif data == "admin_logs":
            await self.show_logs_callback(query, context)
        elif data == "admin_settings":
            await self.show_settings(query, context)
        elif data == "admin_blacklist_menu":
            await self.show_blacklist_menu_callback(query, context)
        elif data == "admin_moderators":
            await self.show_moderators_callback(query, context)
        elif data == "toggle_maintenance":
            self.maintenance_mode = not self.maintenance_mode
            status = "включен" if self.maintenance_mode else "выключен"
            db.log_action(user_id, "toggle_maintenance", f"Режим обслуживания: {status}")
            await self.show_settings(query, context)
        elif data == "export_data":
            await self.export_data_callback(query, context)
        elif data == "cleanup_data":
            await self.cleanup_data_callback(query, context)
        elif data == "backup_db":
            await self.backup_database_callback(query, context)

        # Модераторские команды
        elif data.startswith("mod_"):
            if user_id not in MODERATOR_IDS and user_id not in ADMIN_IDS:
                await query.edit_message_text("❌ У вас нет прав модератора.")
                return

            if data == "mod_view_clan":
                await self.view_blacklist(query, context, BLACKLIST_CLAN)
            elif data == "mod_view_staff":
                await self.view_blacklist(query, context, BLACKLIST_STAFF)
            elif data == "mod_search_blacklist":
                await query.edit_message_text(
                    "🔍 Введите никнейм для поиска в черных списках:",
                    reply_markup=InlineKeyboardMarkup([
                        [InlineKeyboardButton("🔙 Назад", callback_data="mod_back")]
                    ])
                )
                context.user_data['awaiting_blacklist_search'] = True
                return BLACKLIST_SEARCH
            elif data == "mod_blacklist_stats":
                await self.show_blacklist_stats(query, context)

        # Команды черных списков
        elif data.startswith("bl_"):
            if data == "bl_add_clan":
                context.user_data['blacklist_type'] = BLACKLIST_CLAN
                context.user_data['awaiting_blacklist_add'] = True
                await query.edit_message_text(
                    f"➕ Введите никнейм игрока для добавления в {BLACKLIST_CLAN}:\n\n"
                    f"Формат: никнейм причина (или просто никнейм)",
                    reply_markup=InlineKeyboardMarkup([
                        [InlineKeyboardButton("🔙 Назад", callback_data="admin_blacklist_menu")]
                    ])
                )
                return ADD_TO_BLACKLIST
            elif data == "bl_add_staff":
                context.user_data['blacklist_type'] = BLACKLIST_STAFF
                context.user_data['awaiting_blacklist_add'] = True
                await query.edit_message_text(
                    f"➕ Введите никнейм игрока для добавления в {BLACKLIST_STAFF}:\n\n"
                    f"Формат: никнейм причина (или просто никнейм)",
                    reply_markup=InlineKeyboardMarkup([
                        [InlineKeyboardButton("🔙 Назад", callback_data="admin_blacklist_menu")]
                    ])
                )
                return ADD_TO_BLACKLIST
            elif data == "bl_remove_clan":
                context.user_data['blacklist_type'] = BLACKLIST_CLAN
                context.user_data['awaiting_blacklist_remove'] = True
                await query.edit_message_text(
                    f"➖ Введите никнейм игрока для удаления из {BLACKLIST_CLAN}:",
                    reply_markup=InlineKeyboardMarkup([
                        [InlineKeyboardButton("🔙 Назад", callback_data="admin_blacklist_menu")]
                    ])
                )
                return REMOVE_FROM_BLACKLIST
            elif data == "bl_remove_staff":
                context.user_data['blacklist_type'] = BLACKLIST_STAFF
                context.user_data['awaiting_blacklist_remove'] = True
                await query.edit_message_text(
                    f"➖ Введите никнейм игрока для удаления из {BLACKLIST_STAFF}:",
                    reply_markup=InlineKeyboardMarkup([
                        [InlineKeyboardButton("🔙 Назад", callback_data="admin_blacklist_menu")]
                    ])
                )
                return REMOVE_FROM_BLACKLIST
            elif data == "bl_view_clan":
                await self.view_blacklist(query, context, BLACKLIST_CLAN)
            elif data == "bl_view_staff":
                await self.view_blacklist(query, context, BLACKLIST_STAFF)
            elif data == "bl_search":
                await query.edit_message_text(
                    "🔍 Введите никнейм для поиска в черных списках:",
                    reply_markup=InlineKeyboardMarkup([
                        [InlineKeyboardButton("🔙 Назад", callback_data="admin_blacklist_menu")]
                    ])
                )
                context.user_data['awaiting_blacklist_search'] = True
                return BLACKLIST_SEARCH
            elif data == "bl_stats":
                await self.show_blacklist_stats(query, context)
            elif data.startswith("bl_page_"):
                parts = data.split('_')
                list_type = parts[2]
                page = int(parts[3])
                await self.view_blacklist(query, context, list_type, page)

        # Навигация по пользователям
        elif data.startswith("users_page_"):
            parts = query.data.split('_')
            page = int(parts[2])
            search_query = parts[3] if len(parts) > 3 and parts[3] else None
            await self.send_users_page(query, context, page=page, search_query=search_query)

        # Обработка заявок и вопросов
        elif data.startswith("app_"):
            await self.handle_application_action(query, data, context)
        elif data.startswith("question_"):
            await self.handle_question_action(query, data, context)

        # Управление ролями
        elif data.startswith("make_admin_"):
            target_id = int(data.split('_')[2])
            if target_id not in ADMIN_IDS:
                ADMIN_IDS.append(target_id)
                await query.edit_message_text(f"✅ Пользователь {target_id} назначен администратором.")
                db.log_action(user_id, "make_admin", f"Назначен админ: {target_id}")
            else:
                await query.edit_message_text("❌ Пользователь уже администратор.")

        elif data.startswith("make_moderator_"):
            target_id = int(data.split('_')[2])
            if target_id not in MODERATOR_IDS:
                MODERATOR_IDS.append(target_id)
                await query.edit_message_text(f"✅ Пользователь {target_id} назначен модератором.")
                db.log_action(user_id, "make_moderator", f"Назначен модератор: {target_id}")
            else:
                await query.edit_message_text("❌ Пользователь уже модератор.")

        elif data.startswith("ban_user_"):
            target_id = int(data.split('_')[2])
            await query.edit_message_text(f"🚫 Используйте команду /ban для блокировки пользователя.")

        elif data.startswith("unban_user_"):
            target_id = int(data.split('_')[2])
            await query.edit_message_text(f"✅ Используйте команду /unban для разблокировки пользователя.")

        else:
            await query.edit_message_text(
                "❌ Неизвестная команда. Попробуйте снова.",
                reply_markup=self.admin_keyboard()
            )

    # --- МЕТОДЫ ДЛЯ ЧЕРНЫХ СПИСКОВ (НИКИ БЕЗ @) ---
    async def receive_blacklist_add(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Получение данных для добавления в черный список"""
        # Проверяем, что бот вызван в личном чате
        if update.effective_chat.type != "private":
            return ConversationHandler.END

        user_id = update.message.from_user.id
        text = update.message.text

        if text == "❌ Отменить":
            await update.message.reply_text(
                "❌ Добавление отменено.",
                reply_markup=self.main_keyboard(user_id)
            )
            context.user_data.pop('awaiting_blacklist_add', None)
            context.user_data.pop('blacklist_type', None)
            return ConversationHandler.END

        list_type = context.user_data.get('blacklist_type')
        if not list_type:
            await update.message.reply_text("❌ Ошибка: не выбран тип списка.")
            context.user_data.pop('awaiting_blacklist_add', None)
            return ConversationHandler.END

        # Разбираем текст на никнейм и причину
        parts = text.split(' ', 1)
        username = parts[0].strip().lower()
        reason = parts[1] if len(parts) > 1 else f"Добавлен в {list_type}"

        # Добавляем в базу
        if db.add_to_blacklist(username, list_type, reason, user_id):
            # ОТВЕТ ПОЛЬЗОВАТЕЛЮ (НИК БЕЗ @)
            await update.message.reply_text(
                f"✅ Игрок {username} добавлен в {list_type}\n"
                f"📝 Причина: {reason}",
                reply_markup=self.main_keyboard(user_id)
            )
            db.log_action(user_id, "add_to_blacklist", f"{list_type}: {username}")

            # Получаем имя администратора для красивого уведомления
            admin_name = self.format_admin_name(user_id)

            # ФОРМИРУЕМ ТЕКСТ УВЕДОМЛЕНИЯ (НИК БЕЗ @)
            log_message = (
                f"➕ **Добавление в черный список**\n"
                f"• **Администратор:** {admin_name}\n"
                f"• **Список:** {list_type}\n"
                f"• **Игрок:** {username}\n"
                f"• **Причина:** {reason}"
            )

            # --- 1. Отправка в ЛС всем администраторам ---
            failed_admins = []
            for admin_id in ADMIN_IDS:
                if admin_id != user_id:
                    try:
                        await self.application.bot.send_message(
                            admin_id,
                            log_message,
                            parse_mode='Markdown'
                        )
                    except Exception as e:
                        failed_admins.append(str(admin_id))
                        logger.error(f"Ошибка отправки уведомления админу {admin_id}: {e}")

            if failed_admins:
                await update.message.reply_text(
                    f"⚠️ Не удалось отправить уведомление администраторам: {', '.join(failed_admins)}.\n"
                    f"Возможно, они заблокировали бота или не писали ему в ЛС."
                )

            # --- 2. Отправка в групповой чат для логов ---
            if LOG_CHAT_ID:
                try:
                    if LOG_TOPIC_ID:
                        await self.application.bot.send_message(
                            chat_id=LOG_CHAT_ID,
                            text=log_message,
                            message_thread_id=LOG_TOPIC_ID,
                            parse_mode='Markdown'
                        )
                    else:
                        await self.application.bot.send_message(
                            LOG_CHAT_ID,
                            log_message,
                            parse_mode='Markdown'
                        )
                except Exception as e:
                    logger.error(f"Ошибка отправки в лог-чат {LOG_CHAT_ID}: {e}")
                    error_text = "⚠️ Не удалось отправить уведомление в групповой чат."
                    if "message thread not found" in str(e).lower():
                        error_text = f"⚠️ Ошибка: тема с ID {LOG_TOPIC_ID} не найдена. Проверьте правильность ID темы."
                    elif "chat not found" in str(e).lower():
                        error_text = "⚠️ Ошибка: чат не найден. Проверьте права бота в чате."
                    elif "forbidden" in str(e).lower():
                        error_text = "⚠️ Ошибка: бот не имеет прав для отправки в этот чат. Добавьте бота в группу."

                    await update.message.reply_text(error_text)
        else:
            await update.message.reply_text(
                f"❌ Ошибка при добавлении в {list_type}. Возможно, игрок уже в списке.",
                reply_markup=self.main_keyboard(user_id)
            )

        context.user_data.pop('awaiting_blacklist_add', None)
        context.user_data.pop('blacklist_type', None)
        return ConversationHandler.END

    async def receive_blacklist_remove(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Получение данных для удаления из черного списка"""
        # Проверяем, что бот вызван в личном чате
        if update.effective_chat.type != "private":
            return ConversationHandler.END

        user_id = update.message.from_user.id
        text = update.message.text

        if text == "❌ Отменить":
            await update.message.reply_text(
                "❌ Удаление отменено.",
                reply_markup=self.main_keyboard(user_id)
            )
            context.user_data.pop('awaiting_blacklist_remove', None)
            context.user_data.pop('blacklist_type', None)
            return ConversationHandler.END

        list_type = context.user_data.get('blacklist_type')
        if not list_type:
            await update.message.reply_text("❌ Ошибка: не выбран тип списка.")
            context.user_data.pop('awaiting_blacklist_remove', None)
            return ConversationHandler.END

        username = text.strip().lower()

        # Проверяем, есть ли в списке
        if not db.check_in_blacklist(username, list_type):
            await update.message.reply_text(
                f"❌ Игрок {username} не найден в {list_type}",
                reply_markup=self.main_keyboard(user_id)
            )
            context.user_data.pop('awaiting_blacklist_remove', None)
            context.user_data.pop('blacklist_type', None)
            return ConversationHandler.END

        # Удаляем из базы
        if db.remove_from_blacklist(username, list_type):
            # ОТВЕТ ПОЛЬЗОВАТЕЛЮ (НИК БЕЗ @)
            await update.message.reply_text(
                f"✅ Игрок {username} удален из {list_type}",
                reply_markup=self.main_keyboard(user_id)
            )
            db.log_action(user_id, "remove_from_blacklist", f"{list_type}: {username}")

            # Получаем имя администратора для красивого уведомления
            admin_name = self.format_admin_name(user_id)

            # ФОРМИРУЕМ ТЕКСТ УВЕДОМЛЕНИЯ (НИК БЕЗ @)
            log_message = (
                f"➖ **Удаление из черного списка**\n"
                f"• **Администратор:** {admin_name}\n"
                f"• **Список:** {list_type}\n"
                f"• **Игрок:** {username}"
            )

            # --- 1. Отправка в ЛС всем администраторам ---
            failed_admins = []
            for admin_id in ADMIN_IDS:
                if admin_id != user_id:
                    try:
                        await self.application.bot.send_message(
                            admin_id,
                            log_message,
                            parse_mode='Markdown'
                        )
                    except Exception as e:
                        failed_admins.append(str(admin_id))
                        logger.error(f"Ошибка отправки уведомления админу {admin_id}: {e}")

            if failed_admins:
                await update.message.reply_text(
                    f"⚠️ Не удалось отправить уведомление администраторам: {', '.join(failed_admins)}.\n"
                    f"Возможно, они заблокировали бота или не писали ему в ЛС."
                )

            # --- 2. Отправка в групповой чат для логов ---
            if LOG_CHAT_ID:
                try:
                    if LOG_TOPIC_ID:
                        await self.application.bot.send_message(
                            chat_id=LOG_CHAT_ID,
                            text=log_message,
                            message_thread_id=LOG_TOPIC_ID,
                            parse_mode='Markdown'
                        )
                    else:
                        await self.application.bot.send_message(
                            LOG_CHAT_ID,
                            log_message,
                            parse_mode='Markdown'
                        )
                except Exception as e:
                    logger.error(f"Ошибка отправки в лог-чат {LOG_CHAT_ID}: {e}")
                    error_text = "⚠️ Не удалось отправить уведомление в групповой чат."
                    if "message thread not found" in str(e).lower():
                        error_text = f"⚠️ Ошибка: тема с ID {LOG_TOPIC_ID} не найдена. Проверьте правильность ID темы."
                    elif "chat not found" in str(e).lower():
                        error_text = "⚠️ Ошибка: чат не найден. Проверьте права бота в чате."
                    elif "forbidden" in str(e).lower():
                        error_text = "⚠️ Ошибка: бот не имеет прав для отправки в этот чат. Добавьте бота в группу."

                    await update.message.reply_text(error_text)
        else:
            await update.message.reply_text(
                f"❌ Ошибка при удалении из {list_type}",
                reply_markup=self.main_keyboard(user_id)
            )

        context.user_data.pop('awaiting_blacklist_remove', None)
        context.user_data.pop('blacklist_type', None)
        return ConversationHandler.END

    async def receive_blacklist_search(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Получение поискового запроса для черного списка"""
        # Проверяем, что бот вызван в личном чате
        if update.effective_chat.type != "private":
            return ConversationHandler.END

        user_id = update.message.from_user.id
        search_term = update.message.text

        if search_term == "❌ Отменить":
            await update.message.reply_text(
                "❌ Поиск отменен.",
                reply_markup=self.main_keyboard(user_id)
            )
            context.user_data.pop('awaiting_blacklist_search', None)
            return ConversationHandler.END

        # Ищем в обоих списках
        clan_results = db.search_in_blacklist(search_term, BLACKLIST_CLAN)
        staff_results = db.search_in_blacklist(search_term, BLACKLIST_STAFF)

        message = f"🔍 РЕЗУЛЬТАТЫ ПОИСКА: '{search_term}'\n\n"

        if clan_results:
            message += f"❌ ЧСК:\n"
            for item in clan_results:
                message += f"   • {item['username']} - {item['reason']}\n"

        if staff_results:
            message += f"\n🚫 ЧСКК:\n"
            for item in staff_results:
                message += f"   • {item['username']} - {item['reason']}\n"

        if not clan_results and not staff_results:
            message = f"❌ Ничего не найдено по запросу '{search_term}'"

        await update.message.reply_text(
            message,
            reply_markup=self.main_keyboard(user_id)
        )

        context.user_data.pop('awaiting_blacklist_search', None)
        return ConversationHandler.END

    async def view_blacklist(self, query, context, list_type, page=0):
        """Просмотр черного списка"""
        limit = 15
        blacklist = db.get_blacklist(list_type)

        if not blacklist:
            await query.edit_message_text(
                f"📋 {list_type} пуст.",
                reply_markup=InlineKeyboardMarkup([
                    [InlineKeyboardButton("➕ Добавить", callback_data=f"bl_add_{list_type}")],
                    [InlineKeyboardButton("🔙 Назад", callback_data="admin_blacklist_menu")]
                ])
            )
            return

        total_items = len(blacklist)
        total_pages = (total_items + limit - 1) // limit
        start = page * limit
        end = start + limit
        current_page = blacklist[start:end]

        # Формируем сообщение (НИКИ БЕЗ @)
        list_name = "❌ ЧСК (Черный список клана)" if list_type == BLACKLIST_CLAN else "🚫 ЧСКК (Черный список команды)"
        message = f"{list_name}\n"
        message += f"📊 Всего: {total_items} игроков\n\n"

        for i, item in enumerate(current_page, start=start + 1):
            added_by = f" (админ ID:{item['added_by']})" if item['added_by'] != 0 else ""
            message += f"{i}. {item['username']}{added_by}\n"
            if item['reason']:
                message += f"   └ {item['reason']}\n"

        if total_pages > 1:
            message += f"\n📄 Страница {page + 1} из {total_pages}"

        await query.edit_message_text(
            message,
            reply_markup=self.blacklist_view_keyboard(list_type, page, total_pages)
        )

