            moderator_list += f"{i}. {moderator_display} (ID: {moderator_id})\n"

        moderator_list += f"\n📊 Всего модераторов: {len(MODERATOR_IDS)}"

        await update.message.reply_text(moderator_list)

    async def ban_user_command(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Команда для блокировки пользователя"""
        # Проверяем, что бот вызван в личном чате
        if not await self.check_private_chat(update):
            return

        user_id = update.message.from_user.id

        if user_id not in ADMIN_IDS:
            await update.message.reply_text("❌ У вас нет прав для этой команды.")
            return

        if not context.args or len(context.args) < 2:
            await update.message.reply_text("Использование: /ban @username причина_блокировки")
            return

        username = context.args[0]
        reason = ' '.join(context.args[1:])

        # Получаем информацию о пользователе
        user_info = db.get_user_by_username(username)
        if not user_info:
            await update.message.reply_text("❌ Пользователь с таким username не найден.")
            return

        # Блокируем пользователя
        db.ban_user(user_info['user_id'], user_info['username'], reason, user_id)
        db.log_action(user_id, "ban_user", f"Заблокирован: @{username}, причина: {reason}")

        admin_name = self.format_admin_name(user_id)
        await update.message.reply_text(
            f"✅ Пользователь @{user_info['username']} (ID: {user_info['user_id']}) заблокирован.\n"
            f"👮‍♂️ Заблокировал: {admin_name}\n"
            f"📝 Причина: {reason}"
        )

        # Уведомляем всех админов
        for admin_id in ADMIN_IDS:
            if admin_id != user_id:
                try:
                    await self.application.bot.send_message(
                        admin_id,
                        f"🚫 Пользователь @{user_info['username']} заблокирован администратором {admin_name}\n"
                        f"📝 Причина: {reason}"
                    )
                except Exception as e:
                    logger.error(f"Ошибка уведомления админа {admin_id}: {e}")

    async def unban_user_command(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Команда для разблокировки пользователя"""
        # Проверяем, что бот вызван в личном чате
        if not await self.check_private_chat(update):
            return

        user_id = update.message.from_user.id

        if user_id not in ADMIN_IDS:
            await update.message.reply_text("❌ У вас нет прав для этой команды.")
            return

        if not context.args:
            await update.message.reply_text("Использование: /unban @username")
            return

        username = context.args[0]

        # Получаем информацию о пользователе
        user_info = db.get_user_by_username(username)
        if not user_info:
            await update.message.reply_text("❌ Пользователь с таким username не найден.")
            return

        # Проверяем заблокирован ли пользователь
        if not db.is_user_banned(user_info['user_id']):
            await update.message.reply_text("❌ Этот пользователь не заблокирован.")
            return

        # Разблокируем пользователя
        db.unban_user(user_info['user_id'])
        db.log_action(user_id, "unban_user", f"Разблокирован: @{username}")

        admin_name = self.format_admin_name(user_id)
        await update.message.reply_text(
            f"✅ Пользователь @{user_info['username']} (ID: {user_info['user_id']}) разблокирован.\n"
            f"👮‍♂️ Разблокировал: {admin_name}"
        )

    async def show_banned_users(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Показать список заблокированных пользователей"""
        # Проверяем, что бот вызван в личном чате
        if not await self.check_private_chat(update):
            return

        user_id = update.message.from_user.id

        if user_id not in ADMIN_IDS:
            await update.message.reply_text("❌ У вас нет прав администратора.")
            return

        banned_users = db.get_banned_users()
        if not banned_users:
            await update.message.reply_text("✅ Нет заблокированных пользователей.")
            return

        banned_list = "🚫 ЗАБЛОКИРОВАННЫЕ ПОЛЬЗОВАТЕЛИ:\n\n"
        for banned in banned_users:
            banned_by = f"@{banned['banned_by_username']}" if banned[
                'banned_by_username'] else f"ID: {banned['banned_by']}"
            banned_list += (
                f"👤 Пользователь: @{banned['username']} (ID: {banned['user_id']})\n"
                f"📝 Причина: {banned['reason']}\n"
                f"👮‍♂️ Заблокировал: {banned_by}\n"
                f"📅 Дата: {banned['banned_at']}\n"
                f"────────────────────\n"
            )

        await update.message.reply_text(banned_list)

    async def show_users(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Показать список всех пользователей"""
        # Проверяем, что бот вызван в личном чате
        if not await self.check_private_chat(update):
            return

        user_id = update.message.from_user.id

        # Проверяем права администратора
        if user_id not in ADMIN_IDS:
            await update.message.reply_text("❌ У вас нет прав администратора.")
            return

        await self.send_users_page(update, context, page=0)

    async def send_users_page(self, update, context, page=0, search_query=None):
        """Отправить страницу с пользователями"""
        limit = 10
        offset = page * limit

        users = db.get_all_users(limit=limit, offset=offset, search_query=search_query)
        total_users = db.get_users_count(search_query)
        total_pages = (total_users + limit - 1) // limit

        if not users:
            message = "❌ Пользователи не найдены."
            if search_query:
                message = f"❌ Пользователи по запросу '{search_query}' не найдены."
            if isinstance(update, Update):
                await update.message.reply_text(message)
            else:
                await update.edit_message_text(message)
            return

        # Формируем сообщение
        if search_query:
            message = f"👥 ПОЛЬЗОВАТЕЛИ (поиск: '{search_query}')\n\n"
        else:
            message = "👥 ВСЕ ПОЛЬЗОВАТЕЛИ БОТА\n\n"

        for i, user in enumerate(users, start=1):
            user_num = offset + i
            username = f"@{user['username']}" if user['username'] else "без username"
            full_name = f"{user['first_name'] or ''} {user['last_name'] or ''}".strip()
            created_date = user['created_at'].split()[0] if user['created_at'] else "неизвестно"

            message += f"{user_num}. {full_name} ({username})\n"
            message += f"   🆔: {user['user_id']}\n"
            message += f"   📅: {created_date}\n"

            # Добавляем статистику пользователя
            user_stats = db.get_user_stats(user['user_id'])
            if user_stats['applications_count'] > 0 or user_stats['questions_count'] > 0:
                message += f"   📊 Заявок: {user_stats['applications_count']}, Вопросов: {user_stats['questions_count']}\n"

            message += "\n"

        message += f"📊 Всего пользователей: {total_users}"
        if total_pages > 1:
            message += f" (Страница {page + 1} из {total_pages})"

        # Отправляем сообщение с клавиатурой навигации
        if isinstance(update, Update):
            await update.message.reply_text(
                message,
                reply_markup=self.users_keyboard(page, total_pages, search_query)
            )
        else:
            # Если это callback query
            await update.edit_message_text(
                message,
                reply_markup=self.users_keyboard(page, total_pages, search_query)
            )

    async def find_user(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Поиск пользователя"""
        # Проверяем, что бот вызван в личном чате
        if not await self.check_private_chat(update):
            return ConversationHandler.END

        user_id = update.message.from_user.id

        if user_id not in ADMIN_IDS:
            await update.message.reply_text("❌ У вас нет прав администратора.")
            return ConversationHandler.END

        if not context.args:
            await update.message.reply_text(
                "🔍 Введите username, имя или фамилию пользователя для поиска:\n\n"
                "Или нажмите '❌ Отменить' для возврата.",
                reply_markup=self.cancel_keyboard()
            )
            context.user_data['searching_user'] = True
            return USER_SEARCH

        search_query = ' '.join(context.args)
        await self.send_users_page(update, context, page=0, search_query=search_query)
        return ConversationHandler.END

    async def receive_user_search(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Обработка поискового запроса пользователя"""
        # Проверяем, что бот вызван в личном чате
        if not await self.check_private_chat(update):
            return ConversationHandler.END

        user_id = update.message.from_user.id
        search_query = update.message.text

        # Проверяем отмену
        if search_query == "❌ Отменить":
            await update.message.reply_text(
                "❌ Поиск отменен.",
                reply_markup=self.main_keyboard(user_id)
            )
            context.user_data.pop('searching_user', None)
            return ConversationHandler.END

        await self.send_users_page(update, context, page=0, search_query=search_query)
        context.user_data.pop('searching_user', None)
        return ConversationHandler.END

    async def recent_users(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Показать новых пользователей"""
        # Проверяем, что бот вызван в личном чате
        if not await self.check_private_chat(update):
            return

        user_id = update.message.from_user.id

        if user_id not in ADMIN_IDS:
            await update.message.reply_text("❌ У вас нет прав администратора.")
            return

        days = 7
        if context.args:
            try:
                days = int(context.args[0])
            except ValueError:
                pass

        users = db.get_recent_users(days=days)

        if not users:
            await update.message.reply_text(f"❌ Новых пользователей за последние {days} дней не найдено.")
            return

        message = f"🆕 НОВЫЕ ПОЛЬЗОВАТЕЛИ (за последние {days} дней)\n\n"

        for i, user in enumerate(users, start=1):
            username = f"@{user['username']}" if user['username'] else "без username"
            full_name = f"{user['first_name'] or ''} {user['last_name'] or ''}".strip()
            created_date = user['created_at'].split()[0] if user['created_at'] else "неизвестно"

            message += f"{i}. {full_name} ({username})\n"
            message += f"   🆔: {user['user_id']}\n"
            message += f"   📅: {created_date}\n\n"

        message += f"📊 Всего новых пользователей: {len(users)}"

        await update.message.reply_text(message)

    async def user_info(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Информация о конкретном пользователе"""
        # Проверяем, что бот вызван в личном чате
        if not await self.check_private_chat(update):
            return

        user_id = update.message.from_user.id

        if user_id not in ADMIN_IDS:
            await update.message.reply_text("❌ У вас нет прав администратора.")
            return

        if not context.args:
            await update.message.reply_text("Использование: /userinfo <user_id> или /userinfo @username")
            return

        target = context.args[0]

        try:
            # Пробуем найти по ID
            target_id = int(target)
            user_info = db.get_user_by_id(target_id)
        except ValueError:
            # Ищем по username
            user_info = db.get_user_by_username(target)

        if not user_info:
            await update.message.reply_text("❌ Пользователь не найден.")
            return

        # Получаем статистику пользователя
        user_stats = db.get_user_stats(user_info['user_id'])
        is_banned = db.is_user_banned(user_info['user_id'])
        is_admin = user_info['user_id'] in ADMIN_IDS
        is_moderator = user_info['user_id'] in MODERATOR_IDS

        message = "👤 ИНФОРМАЦИЯ О ПОЛЬЗОВАТЕЛЕ\n\n"
        message += f"🆔 ID: {user_info['user_id']}\n"

        if user_info['username']:
            message += f"📱 Username: @{user_info['username']}\n"

        if user_info['first_name']:
            message += f"👤 Имя: {user_info['first_name']}\n"

        if user_info['last_name']:
            message += f"📛 Фамилия: {user_info['last_name']}\n"

        message += f"📅 Дата регистрации: {user_info['created_at']}\n\n"

        message += "📊 СТАТИСТИКА:\n"
        message += f"   📝 Заявок подано: {user_stats['applications_count']}\n"
        message += f"   ❓ Вопросов задано: {user_stats['questions_count']}\n"
        message += f"   💬 Отзывов оставлено: {user_stats['feedback_count']}\n"

        if user_stats['last_activity']:
            message += f"   ⏰ Последняя активность: {user_stats['last_activity']}\n"

        message += f"   🚫 Статус: {'ЗАБЛОКИРОВАН' if is_banned else 'Активен'}\n"
        message += f"   👑 Администратор: {'Да' if is_admin else 'Нет'}\n"
        message += f"   🛡️ Модератор: {'Да' if is_moderator else 'Нет'}\n"

        # Кнопки действий
        keyboard = []
        if not is_banned:
            keyboard.append([InlineKeyboardButton("🚫 Заблокировать", callback_data=f"ban_user_{user_info['user_id']}")])
        else:
            keyboard.append(
                [InlineKeyboardButton("✅ Разблокировать", callback_data=f"unban_user_{user_info['user_id']}")])

        if not is_admin and user_id in ADMIN_IDS:
            keyboard.append(
                [InlineKeyboardButton("👑 Сделать админом", callback_data=f"make_admin_{user_info['user_id']}")])

        if not is_moderator and user_id in ADMIN_IDS:
            keyboard.append([InlineKeyboardButton("🛡️ Сделать модератором",
                                                  callback_data=f"make_moderator_{user_info['user_id']}")])

        keyboard.append([InlineKeyboardButton("🔙 Назад", callback_data="admin_back")])

        reply_markup = InlineKeyboardMarkup(keyboard)
        await update.message.reply_text(message, reply_markup=reply_markup)

    async def ping(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Проверка работоспособности бота"""
        # Проверяем, что бот вызван в личном чате
        if not await self.check_private_chat(update):
            return

        start_time = datetime.now()
        message = await update.message.reply_text("🏓 Понг...")
        end_time = datetime.now()
        ping_time = (end_time - start_time).total_seconds() * 1000

        await message.edit_text(f"🏓 Понг! Задержка: {ping_time:.2f} мс")

    async def feedback(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Обратная связь о работе бота"""
        # Проверяем, что бот вызван в личном чате
        if not await self.check_private_chat(update):
            return ConversationHandler.END

        user_id = update.message.from_user.id

        if db.is_user_banned(user_id):
            await update.message.reply_text("❌ Вы заблокированы и не можете использовать этого бота.")
            return ConversationHandler.END

        await update.message.reply_text(
            "💬 Пожалуйста, оставьте ваш отзыв о работе бота.\n"
            "Вы можете оценить бота от 1 до 5 звезд или просто написать текст.\n\n"
            "Или нажмите '❌ Отмена' для возврата.",
            reply_markup=self.feedback_keyboard()
        )
        return FEEDBACK

    async def receive_feedback(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Получение фидбека от пользователя"""
        # Проверяем, что бот вызван в личном чате
        if not await self.check_private_chat(update):
            return ConversationHandler.END

        user = update.message.from_user
        text = update.message.text

        if text == "❌ Отменить":
            await update.message.reply_text(
                "❌ Отправка отзыва отменена.",
                reply_markup=self.main_keyboard(user.id)
            )
            return ConversationHandler.END

        # Проверяем, есть ли рейтинг в context.user_data
        rating = context.user_data.get('feedback_rating')

        # Сохраняем фидбек
        db.add_feedback(user.id, text, rating)
        db.log_action(user.id, "feedback", f"Рейтинг: {rating}, Текст: {text[:50]}...")

        # Очищаем временные данные
        context.user_data.pop('feedback_rating', None)
        context.user_data.pop('feedback_mode', None)

        thank_you_msg = "✅ Спасибо за ваш отзыв! Мы ценим ваше мнение и учтем его для улучшения бота."
        if rating:
            thank_you_msg = f"✅ Спасибо за оценку {rating}⭐ и отзыв! Мы ценим ваше мнение."

        await update.message.reply_text(
            thank_you_msg,
            reply_markup=self.main_keyboard(user.id)
        )

        # Уведомляем админов о новом фидбеке
        rating_text = f"Рейтинг: {rating}⭐" if rating else "Только текст"
        for admin_id in ADMIN_IDS:
            try:
                await self.application.bot.send_message(
                    admin_id,
                    f"💬 Новый отзыв от @{user.username} ({rating_text}):\n\n{text}"
                )
            except Exception as e:
                logger.error(f"Ошибка уведомления админа {admin_id}: {e}")

        return ConversationHandler.END

    async def bot_status(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Статус бота и статистика"""
        # Проверяем, что бот вызван в личном чате
        if not await self.check_private_chat(update):
            return

        user_id = update.message.from_user.id
        stats = db.get_stats()

        status_text = "🤖 СТАТУС БОТА\n\n"
        status_text += f"🟢 Статус: {'В работе' if not self.maintenance_mode else '🔴 Режим обслуживания'}\n"
        status_text += f"👥 Пользователей: {stats['total_users']}\n"
        status_text += f"📝 Заявок всего: {stats['total_applications']}\n"
        status_text += f"❓ Вопросов всего: {stats['total_questions']}\n"
        status_text += f"💬 Отзывов: {stats['total_feedback']}\n"

        if stats['avg_feedback_rating'] > 0:
            status_text += f"⭐ Средний рейтинг: {stats['avg_feedback_rating']}/5\n"

        status_text += f"\n📊 ЗА СЕГОДНЯ:\n"
        status_text += f"   👥 Новых пользователей: {stats['new_users_today']}\n"
        status_text += f"   📝 Новых заявок: {stats['pending_applications']}\n"
        status_text += f"   ❓ Новых вопросов: {stats['unanswered_questions']}\n\n"

        status_text += f"📋 ЧЕРНЫЕ СПИСКИ:\n"
        status_text += f"   ❌ ЧСК: {stats['blacklist_clan_count']} игроков\n"
        status_text += f"   🚫 ЧСКК: {stats['blacklist_staff_count']} игроков"

        await update.message.reply_text(status_text)

    async def get_user_id(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Получить свой ID"""
        # Проверяем, что бот вызван в личном чате
        if not await self.check_private_chat(update):
            return

        user = update.message.from_user
        role = "Администратор" if user.id in ADMIN_IDS else "Модератор" if user.id in MODERATOR_IDS else "Пользователь"
        await update.message.reply_text(
            f"🆔 Ваш ID: `{user.id}`\n"
            f"📱 Username: @{user.username or 'не установлен'}\n"
            f"👤 Имя: {user.first_name or 'не указано'}\n"
            f"📛 Фамилия: {user.last_name or 'не указана'}\n"
            f"🎭 Роль: {role}",
            parse_mode='Markdown'
        )

    async def maintenance_mode_command(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Включить/выключить режим обслуживания"""
        # Проверяем, что бот вызван в личном чате
        if not await self.check_private_chat(update):
            return

        user_id = update.message.from_user.id

        if user_id not in ADMIN_IDS:
            await update.message.reply_text("❌ У вас нет прав администратора.")
            return

        if not context.args:
            status = "включен" if self.maintenance_mode else "выключен"
            await update.message.reply_text(f"🔧 Режим обслуживания: {status}")
            return

        action = context.args[0].lower()
        if action in ["on", "вкл", "enable"]:
            self.maintenance_mode = True
            await update.message.reply_text("🔴 Режим обслуживания ВКЛЮЧЕН. Бот временно недоступен для пользователей.")
            db.log_action(user_id, "maintenance", "Режим обслуживания включен")
        elif action in ["off", "выкл", "disable"]:
            self.maintenance_mode = False
            await update.message.reply_text("🟢 Режим обслуживания ВЫКЛЮЧЕН. Бот снова доступен.")
            db.log_action(user_id, "maintenance", "Режим обслуживания выключен")
        else:
            await update.message.reply_text("❌ Использование: /maintenance on/off")

    async def show_feedback(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Показать отзывы пользователей"""
        # Проверяем, что бот вызван в личном чате
        if not await self.check_private_chat(update):
            return

        user_id = update.message.from_user.id

        if user_id not in ADMIN_IDS:
            await update.message.reply_text("❌ У вас нет прав администратора.")
            return

        feedback_list = db.get_feedback(limit=20)

        if not feedback_list:
            await update.message.reply_text("💬 Пока нет отзывов от пользователей.")
            return

        message = "💬 ПОСЛЕДНИЕ ОТЗЫВЫ ПОЛЬЗОВАТЕЛЕЙ\n\n"

        for i, feedback in enumerate(feedback_list, 1):
            username = f"@{feedback['username']}" if feedback['username'] else "без username"
            full_name = f"{feedback['first_name'] or ''} {feedback['last_name'] or ''}".strip()
            rating = "⭐" * feedback['rating'] if feedback['rating'] else "📝 Только текст"
            date = feedback['created_at'].split()[0]

            message += f"{i}. {full_name} ({username})\n"
            message += f"   {rating}\n"
            message += f"   💬 {feedback['feedback_text'][:100]}{'...' if len(feedback['feedback_text']) > 100 else ''}\n"
            message += f"   📅 {date}\n\n"

        await update.message.reply_text(message)

    async def notify_user(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Отправить уведомление конкретному пользователю"""
        # Проверяем, что бот вызван в личном чате
        if not await self.check_private_chat(update):
            return

        user_id = update.message.from_user.id

        if user_id not in ADMIN_IDS:
            await update.message.reply_text("❌ У вас нет прав администратора.")
            return

        if len(context.args) < 2:
            await update.message.reply_text("❌ Использование: /notify @username текст_сообщения")
            return

        target_username = context.args[0]
        message_text = ' '.join(context.args[1:])

        user_info = db.get_user_by_username(target_username)
        if not user_info:
            await update.message.reply_text("❌ Пользователь с таким username не найден.")
            return

        try:
            await self.application.bot.send_message(
                user_info['user_id'],
                f"📢 Уведомление от администрации:\n\n{message_text}"
            )
            await update.message.reply_text(f"✅ Уведомление отправлено пользователю @{target_username}")
            db.log_action(user_id, "notify_user", f"Пользователь: {target_username}, Сообщение: {message_text[:50]}...")
        except Exception as e:
            await update.message.reply_text(f"❌ Ошибка отправки уведомления: {e}")

    async def backup_database(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Создать backup базы данных"""
        # Проверяем, что бот вызван в личном чате
        if not await self.check_private_chat(update):
            return

        user_id = update.message.from_user.id

        if user_id not in ADMIN_IDS:
            await update.message.reply_text("❌ У вас нет прав администратора.")
            return

        try:
            # Создаем backup
            backup_filename = f"backup_{datetime.now().strftime('%Y%m%d_%H%M%S')}.db"
            shutil.copy2("bot_database.db", backup_filename)

            await update.message.reply_text(f"✅ Backup базы данных создан: `{backup_filename}`", parse_mode='Markdown')
            db.log_action(user_id, "backup", f"Файл: {backup_filename}")
        except Exception as e:
            await update.message.reply_text(f"❌ Ошибка создания backup: {e}")

    async def export_data(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Экспорт данных в CSV"""
        # Проверяем, что бот вызван в личном чате
        if not await self.check_private_chat(update):
            return

        user_id = update.message.from_user.id

        if user_id not in ADMIN_IDS:
            await update.message.reply_text("❌ У вас нет прав администратора.")
            return

        try:
            # Экспорт пользователей
            users = db.get_all_users(limit=1000)  # Большой лимит для экспорта
            if users:
                output = io.StringIO()
                writer = csv.writer(output)
                writer.writerow(['ID', 'Username', 'First Name', 'Last Name', 'Created At'])
                for user in users:
                    writer.writerow([
                        user['user_id'],
                        user['username'] or '',
                        user['first_name'] or '',
                        user['last_name'] or '',
                        user['created_at']
                    ])

                # Отправляем файл
                bio = io.BytesIO(output.getvalue().encode('utf-8'))
                bio.name = f"users_export_{datetime.now().strftime('%Y%m%d')}.csv"
                await update.message.reply_document(bio, caption="📊 Экспорт пользователей")

            db.log_action(user_id, "export_data", "CSV экспорт пользователей")
        except Exception as e:
            await update.message.reply_text(f"❌ Ошибка экспорта данных: {e}")

    async def cleanup_data(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Очистка старых данных"""
        # Проверяем, что бот вызван в личном чате
        if not await self.check_private_chat(update):
            return

        user_id = update.message.from_user.id

        if user_id not in ADMIN_IDS:
            await update.message.reply_text("❌ У вас нет прав администратора.")
            return

        days = 30
        if context.args:
            try:
                days = int(context.args[0])
            except ValueError:
                pass

        result = db.clear_old_data(days=days)

        message = f"🧹 ОЧИСТКА ДАННЫХ (старше {days} дней)\n\n"
        message += f"📝 Удалено заявок: {result['deleted_applications'] or 0}\n"
        message += f"❓ Удалено вопросов: {result['deleted_questions'] or 0}\n"
        message += f"📋 Удалено логов: {result['deleted_logs'] or 0}"

        await update.message.reply_text(message)
        db.log_action(user_id, "cleanup_data", f"Дней: {days}")

    async def show_logs(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Показать логи действий"""
        # Проверяем, что бот вызван в личном чате
        if not await self.check_private_chat(update):
            return

        user_id = update.message.from_user.id

        if user_id not in ADMIN_IDS:
            await update.message.reply_text("❌ У вас нет прав администратора.")
            return

        logs = db.get_action_logs(limit=20)

        if not logs:
            await update.message.reply_text("📝 Логи действий отсутствуют.")
            return

        message = "📝 ПОСЛЕДНИЕ ДЕЙСТВИЯ\n\n"

        for log in logs:
            username = f"@{log['username']}" if log['username'] else f"ID:{log['user_id']}"
            time = log['created_at'].split()[1][:5]  # только время
            message += f"🕒 {time} | {username} | {log['action']}"
            if log['details']:
                message += f" | {log['details'][:30]}..."
            message += "\n"

        await update.message.reply_text(message)

    async def broadcast(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Рассылка сообщения всем пользователям"""
        # Проверяем, что бот вызван в личном чате
        if not await self.check_private_chat(update):
            return ConversationHandler.END

        user_id = update.message.from_user.id

        if user_id not in ADMIN_IDS:
            await update.message.reply_text("❌ У вас нет прав администратора.")
            return ConversationHandler.END

        if not context.args:
            await update.message.reply_text(
                "📢 Введите сообщение для рассылки всем пользователям:\n\n"
                "Или нажмите '❌ Отменить' для возврата.",
                reply_markup=self.cancel_keyboard()
            )
            return BROADCAST

        message_text = ' '.join(context.args)
        await self.send_broadcast(update, context, message_text)
        return ConversationHandler.END

    async def receive_broadcast(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Получение сообщения для рассылки"""
        # Проверяем, что бот вызван в личном чате
        if not await self.check_private_chat(update):
            return ConversationHandler.END

        user_id = update.message.from_user.id
        text = update.message.text

        if text == "❌ Отменить":
            await update.message.reply_text(
                "❌ Рассылка отменена.",
                reply_markup=self.main_keyboard(user_id)
            )
            return ConversationHandler.END

        await self.send_broadcast(update, context, text)
        return ConversationHandler.END

    async def send_broadcast(self, update: Update, context: ContextTypes.DEFAULT_TYPE, message_text: str):
        """Отправка рассылки"""
        users = db.get_all_users()
        success_count = 0
        fail_count = 0

        progress_msg = await update.message.reply_text(f"📢 Рассылка начата... 0/{len(users)}")

        for i, user in enumerate(users):
            try:
                await self.application.bot.send_message(
                    user['user_id'],
                    f"📢 ОБЪЯВЛЕНИЕ ОТ АДМИНИСТРАЦИИ:\n\n{message_text}"
                )
                success_count += 1

                # Обновляем прогресс каждые 10 сообщений
                if i % 10 == 0:
                    await progress_msg.edit_text(f"📢 Рассылка... {i}/{len(users)}")

                # Небольшая задержка чтобы не превысить лимиты Telegram
                await asyncio.sleep(0.1)

            except Exception as e:
                fail_count += 1
                logger.error(f"Ошибка отправки пользователю {user['user_id']}: {e}")

        await progress_msg.edit_text(
            f"✅ Рассылка завершена!\n"
            f"✅ Успешно: {success_count}\n"
            f"❌ Не удалось: {fail_count}"
        )

        db.log_action(update.message.from_user.id, "broadcast",
                      f"Сообщение: {message_text[:50]}..., Успешно: {success_count}")

    async def help_command(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Расширенная справка по командам"""
