    async def show_feedback_callback(self, query, context: ContextTypes.DEFAULT_TYPE):
        """Показать фидбек через callback"""
        feedback_list = db.get_feedback(limit=10)

        if not feedback_list:
            await query.edit_message_text("💬 Пока нет отзывов от пользователей.", reply_markup=self.admin_keyboard())
            return

        message = "💬 ПОСЛЕДНИЕ ОТЗЫВЫ ПОЛЬЗОВАТЕЛЕЙ\n\n"

        for i, feedback in enumerate(feedback_list, 1):
            username = f"@{feedback['username']}" if feedback['username'] else "без username"
            full_name = f"{feedback['first_name'] or ''} {feedback['last_name'] or ''}".strip()
            rating = "⭐" * feedback['rating'] if feedback['rating'] else "📝 Только текст"
            date = feedback['created_at'].split()[0]

            message += f"{i}. {full_name} ({username})\n"
            message += f"   {rating}\n"
            message += f"   💬 {feedback['feedback_text'][:100]}{'...' if len(feedback['feedback_text']) > 100 else ''}\n"
            message += f"   📅 {date}\n\n"

        await query.edit_message_text(
            message,
            reply_markup=InlineKeyboardMarkup([
                [InlineKeyboardButton("🔙 В админ-панель", callback_data="admin_back")]
            ])
        )

    async def show_logs_callback(self, query, context: ContextTypes.DEFAULT_TYPE):
        """Показать логи через callback"""
        logs = db.get_action_logs(limit=15)

        if not logs:
            await query.edit_message_text("📝 Логи действий отсутствуют.", reply_markup=self.admin_keyboard())
            return

        message = "📝 ПОСЛЕДНИЕ ДЕЙСТВИЯ\n\n"

        for log in logs:
            username = f"@{log['username']}" if log['username'] else f"ID:{log['user_id']}"
            time = log['created_at'].split()[1][:5]  # только время
            message += f"🕒 {time} | {username} | {log['action']}"
            if log['details']:
                message += f" | {log['details'][:30]}..."
            message += "\n"

        await query.edit_message_text(
            message,
            reply_markup=InlineKeyboardMarkup([
                [InlineKeyboardButton("🔙 В админ-панель", callback_data="admin_back")]
            ])
        )

