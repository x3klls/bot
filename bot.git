        await update.message.reply_text(
            "📋 УПРАВЛЕНИЕ ЧЕРНЫМИ СПИСКАМИ\n\n"
            "ЧСК (Чёрный список клана) - игроков нельзя добавлять в клан\n"
            "ЧСКК (Черный список команды клана) - нельзя принимать на должности",
            reply_markup=self.blacklist_menu_keyboard()
        )

    async def stats(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        # Проверяем, что бот вызван в личном чате
        if not await self.check_private_chat(update):
            return

        user_id = update.message.from_user.id
        if user_id not in ADMIN_IDS:
            await update.message.reply_text("❌ У вас нет прав администратора.")
            return

        stats = db.get_stats()
        await update.message.reply_text(
            f"📊 СТАТИСТИКА БОТА:\n\n"
            f"👥 Пользователей: {stats['total_users']}\n"
            f"📝 Заявок: {stats['total_applications']}\n"
            f"❓ Вопросов: {stats['total_questions']}\n"
            f"💬 Отзывов: {stats['total_feedback']}\n"
            f"⏳ Новых заявок: {stats['pending_applications']}\n"
            f"⏳ Новых вопросов: {stats['unanswered_questions']}\n"
            f"🚫 Заблокированных: {stats['banned_users']}\n"
            f"🆕 Новых сегодня: {stats['new_users_today']}\n"
            f"📈 Новых за неделю: {stats['new_users_week']}\n"
            f"⭐ Средний рейтинг: {stats['avg_feedback_rating']}/5\n\n"
            f"📋 ЧЕРНЫЕ СПИСКИ:\n"
            f"❌ ЧСК: {stats['blacklist_clan_count']} игроков\n"
            f"🚫 ЧСКК: {stats['blacklist_staff_count']} игроков"
        )

    async def add_admin(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Команда для добавления администратора"""
        # Проверяем, что бот вызван в личном чате
        if not await self.check_private_chat(update):
            return

        user_id = update.message.from_user.id

        if user_id not in ADMIN_IDS:
            await update.message.reply_text("❌ У вас нет прав для этой команды.")
            return

        if not context.args:
            await update.message.reply_text("Использование: /addadmin <user_id> [username]")
            return

        try:
            new_admin_id = int(context.args[0])
            if new_admin_id not in ADMIN_IDS:
                ADMIN_IDS.append(new_admin_id)

                # Если указан username, добавляем в карту
                if len(context.args) > 1:
                    username = context.args[1]
                    if not username.startswith('@'):
                        username = f"@{username}"
                    ADMIN_USERNAME_MAP[new_admin_id] = username

                await update.message.reply_text(f"✅ Пользователь {new_admin_id} добавлен в администраторы.")
                db.log_action(user_id, "add_admin", f"Добавлен админ: {new_admin_id}")
            else:
                await update.message.reply_text("❌ Этот пользователь уже администратор.")
        except ValueError:
            await update.message.reply_text("❌ Неверный ID пользователя.")

    async def remove_admin(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Команда для удаления администратора"""
        # Проверяем, что бот вызван в личном чате
        if not await self.check_private_chat(update):
            return

        user_id = update.message.from_user.id

        if user_id not in ADMIN_IDS:
            await update.message.reply_text("❌ У вас нет прав для этой команды.")
            return

        if not context.args:
            await update.message.reply_text("Использование: /removeadmin <user_id>")
            return

        try:
            remove_admin_id = int(context.args[0])
            if remove_admin_id in ADMIN_IDS:
                ADMIN_IDS.remove(remove_admin_id)
                # Удаляем из карты если есть
                if remove_admin_id in ADMIN_USERNAME_MAP:
                    del ADMIN_USERNAME_MAP[remove_admin_id]
                await update.message.reply_text(f"✅ Пользователь {remove_admin_id} удален из администраторов.")
                db.log_action(user_id, "remove_admin", f"Удален админ: {remove_admin_id}")
            else:
                await update.message.reply_text("❌ Этот пользователь не является администратором.")
        except ValueError:
            await update.message.reply_text("❌ Неверный ID пользователя.")

