    def format_admin_name(self, admin_id, admin_info=None):
        """Форматирование имени администратора с учетом специальных ID"""
        # Проверяем специальные ID
        if admin_id in ADMIN_USERNAME_MAP:
            return ADMIN_USERNAME_MAP[admin_id]

        # Если нет специального отображения, используем информацию из базы
        if not admin_info:
            admin_info = db.get_admin_info(admin_id)

        if not admin_info:
            return f"Администратор (ID: {admin_id})"

        username = admin_info.get('username')
        first_name = admin_info.get('first_name')
        last_name = admin_info.get('last_name')

        if username:
            return f"@{username}"
        elif first_name and last_name:
            return f"{first_name} {last_name}"
        elif first_name:
            return first_name
        else:
            return f"Администратор (ID: {admin_id})"

    def format_moderator_name(self, moderator_id, moderator_info=None):
        """Форматирование имени модератора с учетом специальных ID"""
        # Проверяем специальные ID
        if moderator_id in MODERATOR_USERNAME_MAP:
            return MODERATOR_USERNAME_MAP[moderator_id]

        # Если нет специального отображения, используем информацию из базы
        if not moderator_info:
            moderator_info = db.get_moderator_info(moderator_id)

        if not moderator_info:
            return f"Модератор (ID: {moderator_id})"

        username = moderator_info.get('username')
        first_name = moderator_info.get('first_name')
        last_name = moderator_info.get('last_name')

        if username:
            return f"@{username}"
        elif first_name and last_name:
            return f"{first_name} {last_name}"
        elif first_name:
            return first_name
        else:
            return f"Модератор (ID: {moderator_id})"

    # ==================== ПРОВЕРКА ТИПА ЧАТА ====================
    async def check_private_chat(self, update: Update) -> bool:
        """Проверяет, что бот вызван в личном чате. Возвращает True, если это ЛС."""
        if update.effective_chat.type != "private":
            await update.message.reply_text(
                f"❌ Бот работает только в личных сообщениях.\n"
                f"Напишите мне в ЛС: @{self.bot_username}"
            )
            return False
        return True

    # ============================================================

    async def start(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        # Проверяем, что бот вызван в личном чате
        if not await self.check_private_chat(update):
            return

        user = update.message.from_user

        # Проверяем режим обслуживания
        if self.maintenance_mode and user.id not in ADMIN_IDS:
            await update.message.reply_text(
                "🔴 Бот временно находится в режиме обслуживания. "
                "Пожалуйста, попробуйте позже.\n\n"
                "Приносим извинения за неудобства!"
            )
            return

        # Проверяем заблокирован ли пользователь
        if db.is_user_banned(user.id):
            await update.message.reply_text("❌ Вы заблокированы и не можете использовать этого бота.")
            return

        db.add_user(user.id, user.username, user.first_name, user.last_name)
        db.log_action(user.id, "start", "Пользователь запустил бота")

        welcome_text = (
            "🎮 Добро пожаловать в бот клана Minecraft dyO!\n\n"
            "Здесь вы можете:\n"
            "• 📝 Подать заявку в модерацию\n"
            "• ❓ Задать вопрос администрации\n"
            "• 📜 Ознакомиться с информацией о клане\n"
            "• 💬 Оставить отзыв о работе бота\n\n"
            "Выберите опцию ниже 👇"
        )

        if user.id in ADMIN_IDS:
            welcome_text += "\n\n👑 У вас есть права администратора!"
        elif user.id in MODERATOR_IDS:
            welcome_text += "\n\n🛡️ У вас есть права модератора!"

        await update.message.reply_text(
            welcome_text,
            reply_markup=self.main_keyboard(user.id)
        )

    async def show_menu(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Показать главное меню"""
        # Проверяем, что бот вызван в личном чате
        if not await self.check_private_chat(update):
            return

        user_id = update.message.from_user.id

        if db.is_user_banned(user_id):
            await update.message.reply_text("❌ Вы заблокированы и не можете использовать этого бота.")
            return

        await update.message.reply_text(
            "🏠 Главное меню бота клана Minecraft dyO",
            reply_markup=self.main_keyboard(user_id)
        )

    async def show_rules(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Показать правила клана"""
        # Проверяем, что бот вызван в личном чате
        if not await self.check_private_chat(update):
            return

        user_id = update.message.from_user.id

        # Проверяем заблокирован ли пользователь
        if db.is_user_banned(user_id):
            await update.message.reply_text("❌ Вы заблокированы и не можете использовать этого бота.")
            return

        # Разбиваем правила на части, если они слишком длинные для одного сообщения
        if len(CLAN_RULES) > 4000:
            rules_parts = [CLAN_RULES[i:i + 4000] for i in range(0, len(CLAN_RULES), 4000)]
            for i, part in enumerate(rules_parts):
                if i == 0:
                    await update.message.reply_text(part)
                else:
                    await update.message.reply_text(part)
        else:
            await update.message.reply_text(CLAN_RULES)

        await update.message.reply_text(
            "Выберите дальнейшее действие:",
            reply_markup=self.main_keyboard(user_id)
        )

    async def admin_panel(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        # Проверяем, что бот вызван в личном чате
        if not await self.check_private_chat(update):
            return

        user_id = update.message.from_user.id
        if user_id not in ADMIN_IDS:
            await update.message.reply_text("❌ У вас нет прав администратора.")
            return

        await update.message.reply_text(
            "👑 Панель администратора:",
            reply_markup=self.admin_keyboard()
        )

    async def moderator_panel(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        # Проверяем, что бот вызван в личном чате
        if not await self.check_private_chat(update):
            return

        user_id = update.message.from_user.id
        if user_id not in MODERATOR_IDS and user_id not in ADMIN_IDS:
            await update.message.reply_text("❌ У вас нет прав модератора.")
            return

        await update.message.reply_text(
            "🛡️ Панель модератора:",
            reply_markup=self.moderator_keyboard()
        )

    async def show_blacklist_menu(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Показать меню управления черными списками"""
        # Проверяем, что бот вызван в личном чате
        if not await self.check_private_chat(update):
            return

        user_id = update.message.from_user.id
        if user_id not in ADMIN_IDS:
            await update.message.reply_text("❌ У вас нет прав администратора.")
